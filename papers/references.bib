	pages = {5--18},
	file = {Williams et al. - 2020 - Potentially harmful therapies A meta‐scientific r.pdf:/Users/johnsakaluk/Zotero/storage/IRMYQNX8/Williams et al. - 2020 - Potentially harmful therapies A meta‐scientific r.pdf:application/pdf;Williams et al. - 2021 - Potentially harmful therapies A meta-scientific r.pdf:/Users/johnsakaluk/Zotero/storage/6RC86BU4/Williams et al. - 2021 - Potentially harmful therapies A meta-scientific r.pdf:application/pdf},
